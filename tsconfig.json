{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./assets/src/*"]
    }
  },
  "include": ["assets/**/*.ts", "assets/**/*.vue"]
}
